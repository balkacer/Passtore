# Producción o API remota (sin proxy). En desarrollo se usa /api → vite proxy.
# VITE_API_BASE_URL=https://api.tu-dominio.com

# Cofre local-first (IndexedDB) + sync por /sync/events — en `npm run dev` ya está activo.
# En build de producción, sin esto las credenciales siguen yendo a POST /credentials (PostgreSQL).
# VITE_USE_LOCAL_VAULT=true
# Opcional: desactivar socket o outbox (por defecto true si el cofre local está activo).
# VITE_USE_SYNC_OUTBOX=true
# VITE_USE_SYNC_SOCKET=true
