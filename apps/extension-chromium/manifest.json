{
  "manifest_version": 3,
  "name": "Passtore",
  "version": "0.0.3",
  "description": "Passtore — MV3; temporary auth + autofill de usuario vía /temporary-auth/deliver.",
  "action": {
    "default_title": "Passtore",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:3000/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
