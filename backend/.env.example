PORT=3000
NODE_ENV=development

# PostgreSQL (compose service name as host when using Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=passtore
DATABASE_PASSWORD=passtore
DATABASE_NAME=passtore

JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Temporary auth sessions (browser/extension pairing — uses same JWT_SECRET with typ claim)
TEMPORARY_PAIRING_PEPPER=change-me-pepper
TEMPORARY_PAIRING_TTL_MS=600000
TEMPORARY_SESSION_TTL_MS=3600000
TEMPORARY_REQUEST_TTL_MS=300000

# Set true to auto-sync schema when NODE_ENV=production (dev/demo only).
DATABASE_SYNC=false

# CORS: comma-separated origins for mobile dev (Metro, physical device IP, etc.).
# Orígenes chrome-extension://… se permiten siempre en código (extensión Passtore); no hace falta listarlos aquí.
CORS_ORIGINS=http://localhost:8081,http://localhost:5173,http://localhost:8080

# WebAuthn / passkeys — RP ID must match the host users sign in from (e.g. localhost or your domain)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Passtore
# Comma-separated allowed origins for ceremony (must include exact scheme + host + port)
WEBAUTHN_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# Optional: Redis for Socket.IO horizontal scaling (omit for single-node)
# REDIS_URL=redis://localhost:6379
