# Normalize text files to LF in the repo (GitHub-friendly).
* text=auto eol=lf

# Treat common binaries explicitly
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.jar binary
*.keystore binary
